# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenRouter fallback (same Anthropic-style API)
OPENROUTER_API_KEY=sk-or-...

# Optional: GitHub token for higher rate limits on private repos
GITHUB_TOKEN=ghp_...

# Vault location (defaults to /Volumes/VeN/Claude-Code-Work/Brain in this workspace)
VAULT_PATH=/path/to/your/obsidian/vault
DB_PATH=state/sbo.db
CHROMA_PATH=state/chroma

# Pipeline settings
SCHEDULE_TIME=07:00
FRESHNESS_DAYS=7
DEFAULT_MODEL=claude-sonnet-4-6
LOG_LEVEL=INFO

# Local semantic search
EMBEDDING_MODEL=google/embeddinggemma-300m
FALLBACK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_TRUNCATE_DIM=128
